+
+    //
+    // quictun-quic: Key extraction for custom data-plane
+    //
+
+    /// Extract 1-RTT keys after handshake completes.
+    ///
+    /// Takes ownership of the Data space crypto keys. After this call,
+    /// the connection can no longer process 1-RTT data packets internally.
+    /// Use this to hand off AEAD/header keys to a custom data plane.
+    pub fn take_1rtt_keys(&mut self) -> Option<Keys> {
+        self.spaces[SpaceId::Data as usize].crypto.take()
+    }
+
+    /// Extract the pre-computed next 1-RTT packet keys (for key update).
+    pub fn take_next_1rtt_keys(&mut self) -> Option<KeyPair<Box<dyn PacketKey>>> {
+        self.next_crypto.take()
+    }
+
+    /// Produce additional 1-RTT key generations for key update.
+    ///
+    /// Each call advances the key schedule and returns the next generation's
+    /// packet keys. Call multiple times to pre-compute key rotations.
+    pub fn produce_next_1rtt_keys(&mut self) -> Option<KeyPair<Box<dyn PacketKey>>> {
+        self.crypto.next_1rtt_keys()
+    }
+
+    /// The local connection ID (used by the peer to address us in short headers).
+    pub fn local_cid(&self) -> &ConnectionId {
+        &self.handshake_cid
+    }
+
+    /// The CID length used for parsing incoming short headers.
+    pub fn local_cid_len(&self) -> usize {
+        self.local_cid_state.cid_len()
+    }
+
+    /// The active remote connection ID (used by us to address the peer).
+    pub fn remote_cid(&self) -> ConnectionId {
+        self.rem_cids.active()
+    }
 }
 
